{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#cc5d33",
					"name": "Brand Red"
				},
				{
					"slug": "secondary",
					"color": "#fbfbfc",
					"name": "Soft Gray"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Ubuntu, sans-serif",
					"slug": "header-font",
					"name": "Ubuntu",
					"fontFace": [
						{
							"fontFamily": "Ubuntu",
							"src": [
								"file:./assets/fonts/Ubuntu-Regular.ttf"
							],
							"fontWeight": "400",
							"fontStyle": "normal"
						},
						{
							"fontFamily": "Ubuntu",
							"src": [
								"file:./assets/fonts/Ubuntu-Medium.ttf"
							],
							"fontWeight": "500",
							"fontStyle": "normal"
						},
						{
							"fontFamily": "Ubuntu",
							"src": [
								"file:./assets/fonts/Ubuntu-Bold.ttf"
							],
							"fontWeight": "700",
							"fontStyle": "normal"
						}
					]
				},
				{
					"fontFamily": "'Open Sans', sans-serif",
					"slug": "body-font",
					"name": "Open Sans",
					"fontFace": [
						{
							"fontFamily": "Open Sans",
							"src": [
								"file:./assets/fonts/OpenSans-VariableFont_wdth,wght.ttf"
							],
							"fontWeight": "300 800",
							"fontStyle": "normal"
						},
						{
							"fontFamily": "Open Sans",
							"src": [
								"file:./assets/fonts/OpenSans-Italic-VariableFont_wdth,wght.ttf"
							],
							"fontWeight": "300 800",
							"fontStyle": "italic"
						}
					]
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body-font)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--header-font)",
					"fontWeight": "700"
				}
			}
		},
		"spacing": {
			"blockGap": "0"
		}
	}
}
