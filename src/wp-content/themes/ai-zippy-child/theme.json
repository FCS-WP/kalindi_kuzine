{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#cc5d33",
					"name": "Brand Red"
				},
				{
					"slug": "secondary",
					"color": "#fbfbfc",
					"name": "Soft Gray"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Roboto, sans-serif",
					"slug": "header-font",
					"name": "Roboto",
					"fontFace": [
						{
							"fontFamily": "Roboto",
							"src": [
								"file:./assets/fonts/Roboto-Bold.woff2"
							],
							"fontWeight": "700",
							"fontStyle": "normal"
						}
					]
				},
				{
					"fontFamily": "'Open Sans', sans-serif",
					"slug": "body-font",
					"name": "Open Sans",
					"fontFace": [
						{
							"fontFamily": "Open Sans",
							"src": [
								"file:./assets/fonts/OpenSans-Regular.woff2"
							],
							"fontWeight": "400",
							"fontStyle": "normal"
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body-font)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--header-font)",
					"fontWeight": "700"
				}
			}
		},
		"spacing": {
			"blockGap": "0"
		}
	}
}
