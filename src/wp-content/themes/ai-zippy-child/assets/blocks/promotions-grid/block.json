{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/promotions-grid",
  "version": "1.0.0",
  "title": "Promotions Grid",
  "category": "ai-zippy",
  "icon": "grid-view",
  "description": "A grid of promotion cards with background images and text overlays.",
  "keywords": [
    "promotions",
    "grid",
    "cards",
    "offers"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "sectionTitle": {
      "type": "string",
      "default": "Promotions Today"
    },
    "promotions": {
      "type": "array",
      "default": [
        {
          "id": 1,
          "imageId": 0,
          "imageUrl": "",
          "title": "FREE DELIVERY",
          "subtitle": "Minimum order of $50"
        },
        {
          "id": 2,
          "imageId": 0,
          "imageUrl": "",
          "title": "20% OFF",
          "subtitle": "On selected items"
        },
        {
          "id": 3,
          "imageId": 0,
          "imageUrl": "",
          "title": "BUY 2 GET 1",
          "subtitle": "Limited time offer"
        }
      ]
    }
  },
  "textdomain": "ai-zippy",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}